# Hybrid Hackathon Environment Variables
# Copy this file to .env for local development

# Google Sheets Webhook URL (from Google Apps Script Web App deployment)
# Leave empty for local development without Google Sheets integration
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: Webhook secret for additional security
# If set, the same secret must be configured in the Apps Script
GOOGLE_SHEETS_WEBHOOK_SECRET=
